# LifeLink AI - Environment Variables
# Copy this file to .env and fill in your API keys

# Google AI Studio (Gemini) API Key - Required
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# MongoDB Connection URI - Optional (falls back to local JSON)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=lifelink_ai

# Google Maps API Key - Optional (for hospital finder)
# Get yours at: https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Backend Configuration
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:5173
